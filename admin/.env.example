# Shared Supabase project: cg-hotels-shared (Grand + Cupertino + admin)
# The publishable/anon key is safe to expose in client code — table access is
# guarded by Row-Level Security (public read; writes require an admin session).
NEXT_PUBLIC_SUPABASE_URL=https://gpazsgmqnrhotwktbggp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_K4bJrcZx3ff_qbBZy6kbxQ_iL9xj1Ia

# Server-only secret (optional; for future use — seed, etc.). Get it from
# Supabase → Project Settings → API → service_role. NEVER expose to the browser;
# do not prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Publish → revalidate. After a room change, the admin pings each public site's
# /api/revalidate so edits show up immediately. The secret must match the
# REVALIDATE_SECRET set on each public site. Leave blank to disable (sites still
# refresh on their own 5-minute ISR window).
REVALIDATE_SECRET=
GRAND_REVALIDATE_URL=https://www.svgrandhotel.com/api/revalidate
CUPERTINO_REVALIDATE_URL=https://www.cupertino-hotel.com/api/revalidate
